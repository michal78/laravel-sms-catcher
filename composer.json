{
    "name": "michal78/laravel-sms-catcher",
    "description": "A development-only inbox for inspecting Laravel SMS notifications.",
    "keywords": ["laravel", "sms", "notifications", "development", "debugging", "mailpit"],
    "homepage": "https://github.com/michal78/laravel-sms-catcher",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Michal Skogemann"
        }
    ],
    "support": {
        "issues": "https://github.com/michal78/laravel-sms-catcher/issues",
        "source": "https://github.com/michal78/laravel-sms-catcher"
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/notifications": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "laravel/pint": "^1.18",
        "larastan/larastan": "^2.9|^3.0"
    },
    "autoload": {
        "psr-4": {
            "SmsCatcher\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "format": "pint",
        "format:test": "pint --test",
        "analyse": "phpstan analyse"
    },
    "extra": {
        "laravel": {
            "providers": [
                "SmsCatcher\\SmsCatcherServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
